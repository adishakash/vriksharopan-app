# Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
API_BASE_URL=https://api.vrisharopan.in

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vrisharopan
DB_USER=vrisharopan_user
DB_PASSWORD=your_strong_password_here
DB_SSL=true
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_256bit_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_256bit_key_here
JWT_REFRESH_EXPIRES_IN=30d

# ─── AWS S3 ──────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=vrisharopan-uploads

# ─── Razorpay ────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── Firebase ────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=vrisharopan
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@vrisharopan.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@vrisharopan.in
SMTP_PASSWORD=your_email_password
SMTP_FROM=Vrisharopan <noreply@vrisharopan.in>

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@vrisharopan.in
ADMIN_DEFAULT_PASSWORD=Change@Password123

# ─── Pricing ─────────────────────────────────────────────────────────────────
TREE_PRICE_MONTHLY=99
WORKER_EARNING_PER_TREE=20
PLATFORM_FEE_PER_TREE=79

# ─── Google Maps ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_server_key

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://vrisharopan.in,https://admin.vrisharopan.in
